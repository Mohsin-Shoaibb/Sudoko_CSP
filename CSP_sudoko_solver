import sys

def get_neighbors(i):
    """Calculates all cells in the same row, column, and 3x3 box."""
    row, col = i // 9, i % 9
    neighbors = set()
    
    for k in range(9):
        neighbors.add(row * 9 + k) 
        neighbors.add(k * 9 + col) 
            
    box_row, box_col = (row // 3) * 3, (col // 3) * 3
    for r in range(box_row, box_row + 3):
        for c in range(box_col, box_col + 3):
            neighbors.add(r * 9 + c)
    
    neighbors.remove(i)
    return neighbors

def initialize_domains(board_str):
    """Converts a string of 81 digits into the initial domain dictionary."""
    clean_board = "".join(board_str.split())
    domains = {}
    for i, char in enumerate(clean_board):
        val = int(char)
        domains[i] = [val] if val != 0 else list(range(1, 10))
    return domains

# --- Constraint Satisfaction (AC-3) ---

def revise(domains, xi, xj):
    """Removes values from domain of xi that conflict with all values in xj."""
    revised = False
    for x in domains[xi][:]:
        if all(x == y for y in domains[xj]):
            domains[xi].remove(x)
            revised = True
    return revised

def ac3(domains, neighbors):
    """Enforces arc consistency across the entire board."""
    queue = [(xi, xj) for xi in range(81) for xj in neighbors[xi]]
    
    while queue:
        (xi, xj) = queue.pop(0)
        if revise(domains, xi, xj):
            if not domains[xi]:
                return False 
            for xk in neighbors[xi]:
                if xk != xj:
                    queue.append((xk, xi))
    return True

#Search Algorithm 
def solve_backtracking(domains, neighbors):
    """Main solver using Backtracking and Forward Checking."""
    if all(len(domains[v]) == 1 for v in range(81)):
        return domains

    unassigned = [v for v in range(81) if len(domains[v]) > 1]
    var = min(unassigned, key=lambda v: len(domains[v]))

    for value in domains[var]:
        consistent = True
        for nb in neighbors[var]:
            if len(domains[nb]) == 1 and domains[nb][0] == value:
                consistent = False
                break
        
        if consistent:
            local_domains = {v: list(d) for v, d in domains.items()}
            local_domains[var] = [value]
            
            if ac3(local_domains, neighbors):
                result = solve_backtracking(local_domains, neighbors)
                if result: 
                    return result
            
    return None


def print_board(domains):
    if not domains:
        print("No solution found.")
        return
    for r in range(9):
        if r % 3 == 0 and r != 0:
            print("-" * 21)
        row_vals = []
        for c in range(9):
            if c % 3 == 0 and c != 0:
                row_vals.append("|")
            val = domains[r * 9 + c][0]
            row_vals.append(str(val))
        print(" ".join(row_vals))

def main(filename):
    with open(filename, 'r') as f:
        board_raw = f.read()

    neighbors = {i: get_neighbors(i) for i in range(81)}
    domains = initialize_domains(board_raw)
    
    # Pre-solve with AC3
    if ac3(domains, neighbors):
        solution = solve_backtracking(domains, neighbors)
        print_board(solution)
    else:
        print("Initial board is unsolvable.")

if __name__ == "__main__":
    main('medium.txt')
